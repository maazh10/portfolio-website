---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
---

<header transition:persist>
  <nav>
    <h2 class="brand"><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
    </div>
    <div class="utility-links">
      <button
        id="theme-toggle"
        class="theme-toggle"
        aria-label="Toggle dark mode"
      >
        <svg
          class="sun-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="moon-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </nav>
  <style>
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      margin: 0;
      padding: 0 1em;
      background: color-mix(in srgb, var(--bg-primary) 80%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(var(--gray), 18%);
      box-shadow: 0 2px 16px rgba(var(--black), 8%);
      transition:
        background-color 0.3s ease,
        border-color 0.3s ease;
    }

    h2 {
      margin: 0;
      font-size: 1.05em;
      letter-spacing: -0.01em;
    }

    h2 a {
      text-decoration: none;
      font-family: "Noto Serif", Georgia, serif;
    }

    h2.brand a:hover {
      color: var(--accent);
    }

    nav {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      height: 72px;
      max-width: 960px;
      margin: 0 auto;
    }

    .internal-links {
      display: flex;
      align-items: center;
      gap: 4px;
      justify-self: center;
      background: var(--bg-primary);
      border: 1px solid rgba(var(--gray), 15%);
      border-radius: 999px;
      padding: 4px;
    }

    nav a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 64px;
      padding: 0.35em 1em;
      font-size: 0.875rem;
      font-weight: 400;
      letter-spacing: 0.01em;
      color: var(--text-secondary);
      border-radius: 999px;
      border: 1px solid transparent;
      text-decoration: none;
      transition:
        color 0.2s ease,
        background-color 0.2s ease,
        border-color 0.2s ease,
        box-shadow 0.2s ease;
    }

    nav a:hover {
      color: var(--text-primary);
      background: color-mix(in srgb, var(--bg-primary) 55%, transparent);
    }

    nav a.active {
      font-weight: 500;
      background: color-mix(in srgb, var(--accent) 10%, transparent);
      border-color: color-mix(in srgb, var(--accent) 40%, transparent);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      box-shadow: 0 1px 3px rgba(var(--black), 8%);
      text-decoration: none;
    }

    .utility-links {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      justify-self: end;
    }

    .brand {
      justify-self: start;
      padding-left: 0.35rem;
    }

    .social-links {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .social-links a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.9rem;
      height: 1.9rem;
      border-radius: 999px;
      border: 1px solid rgba(var(--gray), 22%);
      background: rgba(var(--gray-light), 16%);
      color: var(--text-secondary);
      transition:
        transform 0.2s ease,
        color 0.2s ease,
        border-color 0.2s ease;
    }

    .social-links a:hover {
      transform: translateY(-1px);
      border-color: var(--accent);
      color: var(--accent);
    }

    [data-theme="dark"] .social-links a {
      background: rgba(var(--gray-dark), 35%);
    }

    .theme-toggle {
      position: relative;
      width: 56px;
      height: 30px;
      background: rgba(var(--gray), 0.2);
      border: 2px solid rgba(var(--gray), 0.3);
      border-radius: 999px;
      cursor: pointer;
      transition: all 0.3s ease;
      appearance: none;
      outline: none;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }

    .theme-toggle:hover {
      border-color: var(--accent);
      transform: scale(1.03);
    }

    .theme-toggle:focus {
      box-shadow: 0 0 0 3px rgba(var(--accent), 0.3);
    }

    .theme-toggle svg {
      position: absolute;
      width: 16px;
      height: 16px;
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
      color: var(--text-primary);
    }

    .sun-icon {
      opacity: 1;
      transform: rotate(0deg);
    }

    .moon-icon {
      opacity: 0;
      transform: rotate(180deg);
    }

    :root[data-theme="dark"] .theme-toggle,
    html[data-theme="dark"] .theme-toggle {
      background: var(--accent);
      border-color: var(--accent);
    }

    :root[data-theme="dark"] .sun-icon,
    html[data-theme="dark"] .sun-icon {
      opacity: 0;
      transform: rotate(-180deg);
    }

    :root[data-theme="dark"] .moon-icon,
    html[data-theme="dark"] .moon-icon {
      opacity: 1;
      transform: rotate(0deg);
      color: #ffffff;
    }

    @media (max-width: 720px) {
      nav {
        grid-template-columns: auto 1fr auto;
      }
      .brand {
        padding-left: 0;
      }
      .internal-links {
        justify-self: center;
      }
      .social-links {
        display: none;
      }
    }
  </style>
</header>
<script>
  function updateActiveLink() {
    const pathname = window.location.pathname;
    const links = document.querySelectorAll(".internal-links a");
    links.forEach((link) => {
      const href = link.getAttribute("href");
      const subpath = pathname.match(/[^\/]+/g);
      const isActive =
        href === "/"
          ? pathname === "/"
          : href === pathname || href === "/" + subpath?.[0];
      link.classList.toggle("active", isActive);
    });
  }

  document.addEventListener("astro:page-load", updateActiveLink);
</script>
