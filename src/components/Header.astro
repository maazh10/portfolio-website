---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
---

<header>
  <nav>
    <h2 class="brand"><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
    </div>
    <div class="utility-links">
      <button
        id="theme-toggle"
        class="theme-toggle"
        aria-label="Toggle dark mode"></button>
    </div>
  </nav>
  <style>
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      margin: 0;
      padding: 0 1em;
      background: color-mix(in srgb, var(--bg-primary) 80%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(var(--gray), 18%);
      box-shadow: 0 2px 16px rgba(var(--black), 8%);
      transition:
        background-color 0.3s ease,
        border-color 0.3s ease;
    }
    h2 {
      margin: 0;
      font-size: 1.05em;
      letter-spacing: -0.01em;
    }

    h2 a,
    h2 a.active {
      text-decoration: none;
      font-family: "Noto Serif", Georgia, serif;
    }
    nav {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      height: 72px;
      max-width: 960px;
      margin: 0 auto;
    }
    nav a {
      padding: 0.6em 0.75em;
      color: var(--text-secondary);
      border-bottom: 2px solid transparent;
      text-decoration: none;
      border-radius: 999px;
      transition:
        color 0.25s ease,
        border-color 0.25s ease,
        background-color 0.25s ease,
        transform 0.25s ease;
    }
    nav a.active {
      text-decoration: none;
      border-bottom-color: var(--accent);
    }
    .internal-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      justify-self: center;
    }
    .utility-links {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      justify-self: end;
    }
    .brand {
      justify-self: start;
      padding-left: 0.35rem;
    }

    .social-links {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .social-links a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.9rem;
      height: 1.9rem;
      border-radius: 999px;
      border: 1px solid rgba(var(--gray), 22%);
      background: rgba(var(--gray-light), 16%);
      color: var(--text-secondary);
      transition:
        transform 0.2s ease,
        color 0.2s ease,
        border-color 0.2s ease;
    }
    .social-links a:hover {
      transform: translateY(-1px);
      border-color: var(--accent);
      color: var(--accent);
    }
    [data-theme="dark"] .social-links a {
      background: rgba(var(--gray-dark), 35%);
    }

    .theme-toggle {
      position: relative;
      width: 56px;
      height: 30px;
      background: rgba(var(--gray), 0.2);
      border: 2px solid rgba(var(--gray), 0.3);
      border-radius: 999px;
      cursor: pointer;
      transition: all 0.3s ease;
      appearance: none;
      outline: none;
      overflow: hidden;
    }

    .theme-toggle:hover {
      border-color: var(--accent);
      transform: scale(1.03);
    }

    .theme-toggle:focus {
      box-shadow: 0 0 0 3px rgba(var(--accent), 0.3);
    }

    .theme-toggle::before {
      content: "";
      position: absolute;
      top: 2px;
      left: 2px;
      width: 22px;
      height: 22px;
      background: var(--text-primary);
      border-radius: 50%;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 4px rgba(var(--black), 0.2);
    }

    .theme-toggle::after {
      content: "☀️";
      position: absolute;
      top: 50%;
      left: 7px;
      transform: translateY(-50%);
      font-size: 13px;
      opacity: 1;
      transition: opacity 0.3s ease;
      pointer-events: none;
    }

    :root[data-theme="dark"] .theme-toggle,
    html[data-theme="dark"] .theme-toggle {
      background: var(--accent);
      border-color: var(--accent);
    }

    :root[data-theme="dark"] .theme-toggle::before,
    html[data-theme="dark"] .theme-toggle::before {
      transform: translateX(26px);
      background: #ffffff;
    }

    :root[data-theme="dark"] .theme-toggle::after,
    html[data-theme="dark"] .theme-toggle::after {
      content: "🌙";
      left: auto;
      right: 7px;
    }

    @media (max-width: 720px) {
      nav {
        grid-template-columns: auto 1fr auto;
      }
      .brand {
        padding-left: 0;
      }
      .internal-links {
        justify-self: center;
      }
      .social-links {
        display: none;
      }
    }
  </style>
</header>
